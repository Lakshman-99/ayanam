  "components": {
    "schemas": {
      "ChartCreateRequest": {
        "properties": {
          "birth_name": {
            "type": "string",
            "maxLength": 255,
            "minLength": 1,
            "title": "Birth Name"
          },
          "birth_date": {
            "type": "string",
            "format": "date",
            "title": "Birth Date"
          },
          "birth_time": {
            "type": "string",
            "format": "time",
            "title": "Birth Time"
          },
          "birth_tz": {
            "type": "string",
            "title": "Birth Tz",
            "description": "IANA timezone string, e.g. 'Asia/Kolkata'"
          },
          "birth_lat": {
            "type": "number",
            "maximum": 90.0,
            "minimum": -90.0,
            "title": "Birth Lat",
            "description": "Latitude in decimal degrees"
          },
          "birth_lon": {
            "type": "number",
            "maximum": 180.0,
            "minimum": -180.0,
            "title": "Birth Lon",
            "description": "Longitude in decimal degrees"
          },
          "birth_location_name": {
            "anyOf": [
              { "type": "string", "maxLength": 255 },
              { "type": "null" }
            ],
            "title": "Birth Location Name"
          },
          "client_id": {
            "anyOf": [
              { "type": "string", "format": "uuid" },
              { "type": "null" }
            ],
            "title": "Client Id"
          },
          "ayanamsa": {
            "type": "string",
            "title": "Ayanamsa",
            "description": "Ayanamsa: KP | Lahiri | Raman",
            "default": "KP"
          },
          "house_system": {
            "type": "string",
            "title": "House System",
            "description": "House system: Placidus | Koch | Equal",
            "default": "Placidus"
          }
        },
        "type": "object",
        "required": [
          "birth_name",
          "birth_date",
          "birth_time",
          "birth_tz",
          "birth_lat",
          "birth_lon"
        ],
        "title": "ChartCreateRequest",
        "description": "Request body for creating a natal chart."
      },
      "ChartListItem": {
        "properties": {
          "id": { "type": "string", "format": "uuid", "title": "Id" },
          "chart_type": { "type": "string", "title": "Chart Type" },
          "birth_name": { "type": "string", "title": "Birth Name" },
          "birth_date": {
            "type": "string",
            "format": "date",
            "title": "Birth Date"
          },
          "birth_location_name": {
            "anyOf": [{ "type": "string" }, { "type": "null" }],
            "title": "Birth Location Name"
          },
          "calculated_at": {
            "anyOf": [
              { "type": "string", "format": "date-time" },
              { "type": "null" }
            ],
            "title": "Calculated At"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          },
          "client_id": {
            "anyOf": [
              { "type": "string", "format": "uuid" },
              { "type": "null" }
            ],
            "title": "Client Id"
          }
        },
        "type": "object",
        "required": [
          "id",
          "chart_type",
          "birth_name",
          "birth_date",
          "birth_location_name",
          "calculated_at",
          "created_at",
          "client_id"
        ],
        "title": "ChartListItem",
        "description": "Lightweight chart summary for list views."
      },
      "ChartOut": {
        "properties": {
          "id": { "type": "string", "format": "uuid", "title": "Id" },
          "chart_type": { "type": "string", "title": "Chart Type" },
          "birth_name": { "type": "string", "title": "Birth Name" },
          "birth_date": {
            "type": "string",
            "format": "date",
            "title": "Birth Date"
          },
          "birth_time": {
            "type": "string",
            "format": "time",
            "title": "Birth Time"
          },
          "birth_tz": { "type": "string", "title": "Birth Tz" },
          "birth_lat": { "type": "number", "title": "Birth Lat" },
          "birth_lon": { "type": "number", "title": "Birth Lon" },
          "birth_location_name": {
            "anyOf": [{ "type": "string" }, { "type": "null" }],
            "title": "Birth Location Name"
          },
          "ayanamsa": { "type": "string", "title": "Ayanamsa" },
          "house_system": { "type": "string", "title": "House System" },
          "chart_data": {
            "anyOf": [
              { "additionalProperties": true, "type": "object" },
              { "type": "null" }
            ],
            "title": "Chart Data"
          },
          "engine_version": {
            "anyOf": [{ "type": "string" }, { "type": "null" }],
            "title": "Engine Version"
          },
          "calculated_at": {
            "anyOf": [
              { "type": "string", "format": "date-time" },
              { "type": "null" }
            ],
            "title": "Calculated At"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          },
          "client_id": {
            "anyOf": [
              { "type": "string", "format": "uuid" },
              { "type": "null" }
            ],
            "title": "Client Id"
          }
        },
        "type": "object",
        "required": [
          "id",
          "chart_type",
          "birth_name",
          "birth_date",
          "birth_time",
          "birth_tz",
          "birth_lat",
          "birth_lon",
          "birth_location_name",
          "ayanamsa",
          "house_system",
          "chart_data",
          "engine_version",
          "calculated_at",
          "created_at",
          "client_id"
        ],
        "title": "ChartOut",
        "description": "Chart response — includes full computed data."
      },
      "ClientCreate": {
        "properties": {
          "full_name": {
            "type": "string",
            "maxLength": 255,
            "minLength": 1,
            "title": "Full Name"
          },
          "gender": {
            "type": "string",
            "pattern": "^(male|female|other)$",
            "title": "Gender",
            "default": "male"
          },
          "date_of_birth": {
            "type": "string",
            "format": "date",
            "title": "Date Of Birth"
          },
          "time_of_birth": {
            "type": "string",
            "format": "time",
            "title": "Time Of Birth"
          },
          "place_of_birth": {
            "type": "string",
            "maxLength": 255,
            "minLength": 1,
            "title": "Place Of Birth"
