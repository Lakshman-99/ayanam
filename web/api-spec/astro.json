    "/api/v1/clients/{client_id}/chart": {
      "get": {
        "tags": ["Clients"],
        "summary": "Get Client Chart",
        "description": "Return the most recent natal chart for a client.",
        "operationId": "get_client_chart_api_v1_clients__client_id__chart_get",
        "security": [{ "HTTPBearer": [] }],
        "parameters": [
          {
            "name": "client_id",
            "in": "path",
