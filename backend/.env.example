# =============================================================================
# KP Astrology Backend — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://kp_user:changeme@localhost:5432/kp_astro
DATABASE_URL_SYNC=postgresql+psycopg2://kp_user:changeme@localhost:5432/kp_astro

# -----------------------------------------------------------------------------
# Redis / Celery
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# -----------------------------------------------------------------------------
# JWT (RS256)
# Generate keys: openssl genrsa -out keys/private.pem 2048
#                openssl rsa -in keys/private.pem -pubout -out keys/public.pem
# -----------------------------------------------------------------------------
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_ENV=development
APP_NAME=KP Astrology API
DEBUG=true
LOG_LEVEL=DEBUG

# JSON array format required by pydantic-settings for list[str] fields
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# -----------------------------------------------------------------------------
# Swiss Ephemeris
# Download .se1 files from: https://www.astro.com/swisseph/swefiles.htm
# Place in the directory below (seas_18.se1, semo_18.se1, sepl_18.se1 etc.)
# -----------------------------------------------------------------------------
EPHE_PATH=./data/ephemeris

# -----------------------------------------------------------------------------
# Rate limiting (slowapi format: "N/period" where period is second/minute/hour)
# -----------------------------------------------------------------------------
RATE_LIMIT_DEFAULT=1000/minute
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_CHART=100/minute

# -----------------------------------------------------------------------------
# GeoNames (Phase 2 — place autocomplete)
# Register free at: https://www.geonames.org/login
# -----------------------------------------------------------------------------
GEONAMES_USERNAME=demo

# -----------------------------------------------------------------------------
# Storage (Phase 3 — PDF reports)
# -----------------------------------------------------------------------------
S3_BUCKET=
S3_REGION=ap-south-1
S3_ACCESS_KEY=
S3_SECRET_KEY=

# -----------------------------------------------------------------------------
# Sentry (Phase 2 — error tracking)
# -----------------------------------------------------------------------------
SENTRY_DSN=
